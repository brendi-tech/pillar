{
  "name": "@pillar-ai/angular",
  "version": "0.1.8",
  "description": "Angular SDK for Pillar product copilot — AI assistant for SaaS and web apps",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "dev": "ng-packagr -p ng-package.json --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "angular",
    "copilot",
    "assistant",
    "ai",
    "sdk",
    "saas",
    "embedded",
    "agent"
  ],
  "author": "Pillar Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pillarhq/sdk-angular",
    "directory": "packages/sdk-angular"
  },
  "homepage": "https://trypillar.com",
  "bugs": {
    "url": "https://github.com/pillarhq/sdk-angular/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@angular/core": ">=17.0.0",
    "@angular/common": ">=17.0.0"
  },
  "dependencies": {
    "@pillar-ai/sdk": "^0.1.8"
  },
  "devDependencies": {
    "@angular/compiler": "^17.3.0",
    "@angular/compiler-cli": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/common": "^17.3.0",
    "ng-packagr": "^17.3.0",
    "tslib": "^2.6.2",
    "typescript": "~5.3.0",
    "zone.js": "~0.14.0"
  },
  "sideEffects": false
}

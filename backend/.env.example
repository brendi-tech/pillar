# =============================================================================
# Pillar Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Required variables are marked with [REQUIRED].
# Optional variables have sensible defaults.

# =============================================================================
# DATABASE
# =============================================================================

HC_POSTGRES_DB=pillar
HC_POSTGRES_USER=postgres
HC_POSTGRES_PASSWORD=postgres            # [REQUIRED] Change in production
HC_POSTGRES_HOST=localhost               # Use "db" if running via docker compose
HC_POSTGRES_PORT=5432

# =============================================================================
# REDIS
# =============================================================================

REDIS_URL=redis://localhost:6379         # Use "redis://redis:6379" in docker compose

# =============================================================================
# DJANGO
# =============================================================================

DJANGO_SECRET_KEY=                       # [REQUIRED] Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_LOG_LEVEL=INFO

# Comma-separated. Set in production.
# ALLOWED_HOSTS=yourdomain.com
# CORS_ALLOWED_ORIGINS=https://yourdomain.com

# =============================================================================
# AI PROVIDERS
# =============================================================================
# You need at least one provider. OpenRouter gives access to multiple models
# through a single key.

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google (Gemini) -- used for embeddings by default
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

# OpenRouter -- routes to multiple model providers
# OPENROUTER_API_KEY=sk-or-...

# Cohere -- used for reranking search results (optional, improves quality)
# COHERE_API_KEY=

# Default model selection
DEFAULT_LLM_MODEL=anthropic/flagship
DEFAULT_VISION_MODEL=anthropic/flagship

# =============================================================================
# RAG CONFIGURATION
# =============================================================================
# These defaults work well for most use cases. Adjust if needed.

RAG_EMBEDDING_MODEL=gemini-embedding-001
RAG_EMBEDDING_DIMENSIONS=1536
RAG_EMBEDDING_PROVIDER=google
RAG_CHUNK_SIZE=1024
RAG_CHUNK_OVERLAP=200
RAG_DEFAULT_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.5

# Cohere reranking (requires COHERE_API_KEY)
COHERE_RERANK_ENABLED=true
COHERE_RERANK_MODEL=rerank-v3.5
COHERE_RERANK_TOP_N=5

# =============================================================================
# HATCHET (Workflow Orchestration)
# =============================================================================
# [REQUIRED] Hatchet runs background jobs: source syncing, content processing,
# embedding generation, etc. Use Hatchet Cloud or self-host.
# https://hatchet.run

HATCHET_CLIENT_TOKEN=                    # [REQUIRED] From your Hatchet dashboard
HATCHET_SERVER_URL=https://app.hatchet.run
HATCHET_NAMESPACE=pillar

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================

# Firecrawl -- web crawling for website sources
# https://firecrawl.dev (use API key or self-host)
# FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev

# Unified.to -- Zendesk/Intercom integration
# UNIFIED_TO_API_KEY=
# UNIFIED_TO_WORKSPACE_ID=

# OpenClaw -- AI agent browser testing (agent score)
# Local: start with `docker compose up -d` (runs on port 8080)
# Production: set to Cloud Run service URL
OPENCLAW_SERVICE_URL=http://localhost:8080

# =============================================================================
# STORAGE
# =============================================================================
# Default: local filesystem. For production, use GCS or S3.

STORAGE_BACKEND=local
# GS_BUCKET_NAME=your-bucket
# GCP_PROJECT_ID=your-project

# =============================================================================
# EMAIL (Optional)
# =============================================================================
# Without email config, emails are printed to console.

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# SENDGRID_API_KEY=
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# AUTH (Optional)
# =============================================================================
# OAuth providers for admin dashboard login.

# GitHub OAuth
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_SECRET=

# Google OAuth
# GOOGLE_WEB_OAUTH_CLIENT_ID=
# GOOGLE_WEB_OAUTH_SECRET_ID=

# =============================================================================
# URLS
# =============================================================================

FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# =============================================================================
# FRONTEND (Next.js)
# =============================================================================

NEXT_PUBLIC_API_URL=http://localhost:8000

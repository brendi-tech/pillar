{
  "$schema": "https://openclaw.ai/schema/config.json",
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/google/gemini-2.5-flash"
      },
      "heartbeat": {
        "every": "0m"
      }
    }
  },
  "env": {
    "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}"
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "none"
    },
    "http": {
      "endpoints": {
        "responses": { "enabled": true }
      }
    }
  },
  "browser": {
    "enabled": true,
    "headless": true
  },
  "skills": {
    "load": {
      "extraDirs": ["skills"]
    }
  }
}
